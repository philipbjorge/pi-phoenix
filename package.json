{
  "name": "pi-phoenix",
  "version": "0.1.3",
  "description": "Phoenix tracing extension for pi",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "bin": {
    "pi-phoenix-sync-openrouter": "bin/sync-openrouter.mjs"
  },
  "files": [
    "index.ts",
    "src",
    "bin",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "phoenix",
    "tracing",
    "opentelemetry"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philipbjorge/pi-phoenix.git"
  },
  "homepage": "https://github.com/philipbjorge/pi-phoenix#readme",
  "bugs": {
    "url": "https://github.com/philipbjorge/pi-phoenix/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.68",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@arizeai/phoenix-otel": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "strip-ansi": "^7.2.0"
  }
}
